{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "exhibition",
        "webinar"
      ],
      "required": true
    },
    "date": {
      "type": "string"
    },
    "time": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "registrationLink": {
      "type": "string"
    },
    "isUpcoming": {
      "type": "boolean",
      "default": true
    },
    "sortOrder": {
      "type": "integer"
    }
  }
}
